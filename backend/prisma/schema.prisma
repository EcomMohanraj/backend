datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String?   @map("password_hash")
  role         String    @default("customer") // "customer" | "admin"
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  customer     Customer?

  @@map("users")
}

model Customer {
  id        String    @id @default(uuid())
  userId    String?   @unique @map("user_id")
  name      String
  email     String    @unique
  phone     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  addresses Address[]
  orders    Order[]
  reviews   Review[]

  @@map("customers")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String
  image       String
  price       Float
  stock       Int         @default(0)
  categoryId  String      @map("category_id")
  nutrition   Json?       @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]
  reviews     Review[]

  @@map("products")
}

model Address {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  address    String
  city       String
  pincode    String
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Order {
  id         String      @id @default(uuid())
  customerId String?     @map("customer_id")
  amount     Float
  status     String      @default("pending") // pending, paid, confirmed, packed, shipped, delivered, cancelled
  paymentId  String?     @map("payment_id")
  address    String
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      OrderItem[]
  payments   Payment[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  amount        Float
  status        String   @default("pending") // pending, success, failed
  provider      String   @default("razorpay")
  transactionId String?  @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  customerId String   @map("customer_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model BlogPost {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  image     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blog_posts")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("categories")
}

model StoreSettings {
  id              String   @id @default("default")
  storeName       String   @default("Milky Mushrooms") @map("store_name")
  contactNumber   String   @default("+91 99887 76655") @map("contact_number")
  email           String   @default("contact@milkymushrooms.com")
  deliveryCharges Float    @default(50.0) @map("delivery_charges")
  taxPercentage   Float    @default(5.0) @map("tax_percentage")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

